# ============================================================
# ERubricas — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Django
SECRET_KEY=django-insecure-troque-por-uma-chave-segura-em-producao
DJANGO_SETTINGS_MODULE=config.settings.production

# Hosts permitidos (Railway fornece o domínio automaticamente)
# Exemplo: erubricas.up.railway.app,meudominio.com.br
ALLOWED_HOSTS=erubricas.up.railway.app

# Banco de dados — Railway PostgreSQL fornece DATABASE_URL automaticamente
# Formato: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://user:password@host:5432/dbname

# ============================================================
# Após o primeiro deploy, rode via Railway Shell:
#   python manage.py seed_plans
#   python manage.py seed_initial_data
#   python manage.py seed_all_rubricas
#   python manage.py createsuperuser
# ============================================================
